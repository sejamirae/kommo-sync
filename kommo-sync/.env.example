# Copie para .env e preencha os valores

# Render fornece automaticamente via render.yaml
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/kommo_sync

# Kommo — crie em: https://www.kommo.com/developers/
KOMMO_CLIENT_ID=seu_client_id
KOMMO_CLIENT_SECRET=seu_client_secret
KOMMO_REDIRECT_URI=https://seu-app.onrender.com/oauth/callback
KOMMO_DOMAIN=suaconta.kommo.com   # sem https://

# String aleatória para validar webhooks (ex: openssl rand -hex 32)
WEBHOOK_SECRET=
